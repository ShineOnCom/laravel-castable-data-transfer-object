{
    "name": "jessarcher/laravel-castable-data-transfer-object",
    "description": "Automatically cast JSON columns to rich PHP objects in Laravel using Spatie's data-transfer-object class",
    "keywords": [
        "jessarcher",
        "laravel-castable-data-transfer-object",
        "castable-data-transfer-object",
        "data-transfer-object",
        "laravel-castable-value-object",
        "castable-value-object",
        "value-object"
    ],
    "homepage": "https://github.com/jessarcher/laravel-castable-data-transfer-object",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Jess Archer",
            "email": "jess@jessarcher.com",
            "homepage": "https://jessarcher.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "spatie/data-transfer-object": "^3.0.4",
        "thecodingmachine/safe": "^1.3|^2.0|^3.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^6.0|^7.0|^8.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "JessArcher\\CastableDataTransferObject\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JessArcher\\CastableDataTransferObject\\Tests\\": "tests"
        }
    },
    "scripts": {
        "psalm": "vendor/bin/psalm",
        "test": "./vendor/bin/testbench package:test --parallel --no-coverage",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
